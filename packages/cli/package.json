{
  "name": "@illustrate.md/cli",
  "version": "0.1.0",
  "description": "Terminal UI for illustrate.md - ASCII wireframing and diagramming",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "illustrate": "./dist/index.js"
  },
