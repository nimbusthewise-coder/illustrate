{
  "name": "@illustrate.md/cli",
  "version": "0.1.0",
  "description": "Command-line interface for illustrate.md",
  "type": "module",
  "bin": {
    "illustrate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "illustrate",
    "ascii",
    "diagram",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@illustrate.md/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "optionalDependencies": {
    "clipboardy": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
